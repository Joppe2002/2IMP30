prediction = this-&gt;predictStorm();%0D
%0D
printf(&quot;prediction direction   = %25d \n&quot;, prediction-&gt;pred_direction);%0D
printf(&quot;prediction probability = %25f \n&quot;, prediction-&gt;pred_probability);%0D
printf(&quot;prediction severity    = %25f \n&quot;, prediction-&gt;pred_severity);%0D
printf(&quot;prediction speed       = %25f \n&quot;, prediction-&gt;pred_speed);%0D
%0D
this-&gt;st_pred_direction   = prediction-&gt;pred_direction;%0D
this-&gt;st_pred_probability = prediction-&gt;pred_probability ;%0D
this-&gt;st_pred_severity    = prediction-&gt;pred_severity;%0D
this-&gt;st_pred_speed       = prediction-&gt;pred_speed;</_bodyData>
			</IBody>
			</_itsBody>
		</IPrimitiveOperation>
