			<_concurrency type="a">Sequential</_concurrency>
			<_protection type="a">iPublic</_protection>
			<_static type="a">0</_static>
			<_constant type="a">0</_constant>
			<_itsBody type="p"><IBody type="e">
				<_bodyData type="a">if(Actor == GOVERNMENT) {%0D
	printf(&quot;Notify Government\n&quot;);%0D
} else if (Actor == EMERGENCY_RESPONDER) {%0D
	printf(&quot;Notify Emergency Responders\n&quot;);%0D
} else {%0D
	printf(&quot;Notify --- --- ??? --- ---\n&quot;);%0D
}%0D
%0D
float probability 	= this-&gt;st_pred_probability;%0D
float severity 		= this-&gt;st_pred_severity;%0D
%0D
%0D
printf(&quot;NOTIFY - STORM approaching with severity: %25f, with probability: %25f \n&quot;, severity, probability); </_bodyData>
			</IBody>
			</_itsBody>
			<AggregatesList type="e">
				<value>GUID 0c47711d-0a05-4494-855b-2a440a56ddbb</value>
			</AggregatesList>
