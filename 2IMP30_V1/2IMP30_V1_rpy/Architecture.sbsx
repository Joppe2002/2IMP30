			<_static type="a">0</_static>
			<_constant type="a">0</_constant>
			<_itsBody type="p"><IBody type="e">
				<_bodyData type="a">printf(&quot;Do prediction \n&quot;);%0D
%0D
Storm_Prediction::Storm_Prediction_Result* result = new Storm_Prediction::Storm_Prediction_Result();%0D
%0D
result-&gt;pred_direction   = this-&gt;wind_direction;%0D
result-&gt;pred_probability = this-&gt;test_probability;%0D
result-&gt;pred_severity    = (float)this-&gt;wind_direction * (float)this-&gt;precipitation_type + (float)4.0;%0D
result-&gt;pred_speed       = (float)this-&gt;wind_speed * (float)10.0;%0D
%0D
return result;</_bodyData>
			</IBody>
			</_itsBody>
		</IPrimitiveOperation>
		<IPrimitiveOperation type="e">
			<_id type="a">GUID 3acdfd18-9581-452f-83d7-f0008a0fdae6</_id>
			<_myState type="a">8192</_myState>
