				<_body type="a">                                             // no tsunami -&gt; storm-only ladder%0D
switch (prev_warning_type) {%0D
    case 0: warning_message = no_warning;          break;%0D
    case 1: warning_message = stay_alert;          break;%0D
    case 2: warning_message = secure_and_prepare;  break;%0D
    case 3: warning_message = prepare_to_evacuate; break;%0D
    case 4: warning_message = take_shelter_now;    break;%0D
}%0D
</_body>
			</IAction>
