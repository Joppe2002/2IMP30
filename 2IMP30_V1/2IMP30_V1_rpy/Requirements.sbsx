		<IRequirement type="e">
			<_id type="a">GUID 5af2423d-c916-4589-98a0-22ad635bada2</_id>
			<_myState type="a">8192</_myState>
			<_name type="a">DataCollection</_name>
			<_modifiedTimeWeak type="a">5.15.2026::9:12:4</_modifiedTimeWeak>
			<_modifiedTime type="a">5.15.2026::9:12:4</_modifiedTime>
			<_body type="a">{\rtf1\ansi\ansicpg1252\deff0\deflang1043{\fonttbl{\f0\fnil\fcharset0 Arial;}}%0D
\viewkind4\uc1\pard\fs20 The system shall collect environmental data from satellite, airborne, and underwater sensor platforms.\par%0D
}%0D
</_body>
			<reqID type="a">REQ_01</reqID>
		</IRequirement>
		<IRequirement type="e">
			<_id type="a">GUID be878534-aece-4ad6-8353-7447c1c4585e</_id>
			<_myState type="a">8192</_myState>
