			<_lastID type="a">1</_lastID>
			<_body type="a">{\rtf1\ansi\ansicpg1252\deff0\deflang1043{\fonttbl{\f0\fnil\fcharset0 Arial;}}%0D
\viewkind4\uc1\pard\fs20 Alerts sent via all channels shall be easily understood by the people in the affected region,\par%0D
taking into account the diverse populations.\par%0D
}%0D
</_body>
