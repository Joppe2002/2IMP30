			<_body type="a">{\rtf1\ansi\ansicpg1252\deff0\deflang1043{\fonttbl{\f0\fnil\fcharset0 Arial;}}%0D
\viewkind4\uc1\pard\fs20 Remote areas that may have limited connectivity shall be taken into account when sending alerts.\par%0D
\par%0D
