			<_modifiedTimeWeak type="a">5.16.2026::11:19:4</_modifiedTimeWeak>
			<_modifiedTime type="a">5.16.2026::11:19:4</_modifiedTime>
			<_body type="a">{\rtf1\ansi\ansicpg1252\deff0\deflang1043{\fonttbl{\f0\fnil\fcharset0 Arial;}}%0D
\viewkind4\uc1\pard\fs20 In case of emergency, a notification shall be relayed to an installable app to the affected region.\par%0D
}%0D
</_body>
		</IRequirement>
		<IRequirement type="e">
			<_id type="a">GUID 28bfca12-2e67-4fc3-9e80-89141b08f270</_id>
