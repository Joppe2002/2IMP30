		<IUseCase type="e">
			<_id type="a">GUID ba94c93b-a9e3-4b5e-a877-8bfe3c476763</_id>
			<_myState type="a">8192</_myState>
			<_name type="a">Relay_Weather_Info</_name>
			<_modifiedTimeWeak type="a">1.2.1990::0:0:0</_modifiedTimeWeak>
			<_description type="p"><IDescription type="e">
				<_textRTF type="a">{\rtf1\ansi\ansicpg1252\deff0\deflang1033{\fonttbl{\f0\fnil\fcharset0 Arial;}}%0D
\viewkind4\uc1\pard\b\fs20 Pre-Condition\par%0D
\b0 1) A new weather forecast has been generated\par%0D
\par%0D
\b Trigger\par%0D
\b0 1) Generate_Weather_Forecast has generated a new forecast\par%0D
2) A researcher requests weather forecast data\b\par%0D
\par%0D
Post-Condition\par%0D
\b0 1) The weather forecast is available via a website and an app\par%0D
2) More extensive data is send to a researcher if requested\par%0D
\b\par%0D
Main Scenario\par%0D
\b0 1) The system has produced a new weather forecast\par%0D
2) The website and app are updated based on the new data\par%0D
3) When a Civilian or News Outlets access the app or website the local weather forecast is shown in the local language and local standard units.\b\par%0D
\par%0D
Alternative Scenario\par%0D
\b0 1) If a researcher requests data, the relevant data is send per email to the researcher in the requested language\par%0D
\par%0D
\par%0D
}%0D
</_textRTF>
			</IDescription>
			</_description>
